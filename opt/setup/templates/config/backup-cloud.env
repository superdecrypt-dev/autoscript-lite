# Backup cloud config for CLI helper (`backup-manage`).
# Default mode:
# - Google Drive = local backup + upload/sync target via rclone
# - Cloudflare R2 = remote archive target via rclone/S3-compatible backend
#
# Example:
#   BACKUP_GDRIVE_REMOTE="gdrive:autoscript-backups"
#   BACKUP_R2_REMOTE="r2:autoscript-backups"
# After editing this file, no daemon restart is required.

BACKUP_RCLONE_BIN="rclone"
BACKUP_GDRIVE_REMOTE=""
BACKUP_R2_REMOTE=""
