OPENVPN_PROFILE_DIR=__OPENVPN_PROFILE_DIR__
OPENVPN_METADATA_DIR=__OPENVPN_METADATA_DIR__
OPENVPN_SERVER_NAME=__OPENVPN_SERVER_NAME__
OPENVPN_PORT_TCP=__OPENVPN_PORT_TCP__
OPENVPN_PUBLIC_PORT_TCP=__OPENVPN_PUBLIC_PORT_TCP__
OPENVPN_PUBLIC_HOST=__OPENVPN_PUBLIC_HOST__
OPENVPN_MANAGEMENT_HOST=__OPENVPN_MANAGEMENT_HOST__
OPENVPN_MANAGEMENT_PORT=__OPENVPN_MANAGEMENT_PORT__
OPENVPN_WS_PROXY_PORT=__OPENVPN_WS_PROXY_PORT__
OPENVPN_WS_PUBLIC_PATH=__OPENVPN_WS_PUBLIC_PATH__
