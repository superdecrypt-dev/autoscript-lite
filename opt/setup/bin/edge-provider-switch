#!/usr/bin/env bash
set -euo pipefail

TARGET_PROVIDER="${1:-}"

if [[ -z "${TARGET_PROVIDER}" ]]; then
  echo "Usage: edge-provider-switch <go|haproxy>" >&2
  exit 1
fi

case "${TARGET_PROVIDER}" in
  go|haproxy) ;;
  *)
    echo "Provider tidak dikenal: ${TARGET_PROVIDER}" >&2
    exit 1
    ;;
esac

SETUP_CANDIDATES=(
  "/usr/local/lib/autoscript-setup/setup.sh"
  "/root/project/autoscript/setup.sh"
)

SETUP_FILE=""
for candidate in "${SETUP_CANDIDATES[@]}"; do
  if [[ -f "${candidate}" ]]; then
    if [[ "${TARGET_PROVIDER}" == "go" ]]; then
      candidate_root="$(cd -- "$(dirname "${candidate}")" && pwd)"
      if [[ ! -s "${candidate_root}/opt/edge/dist/edge-mux-linux-amd64" && ! -s "${candidate_root}/opt/edge/dist/edge-mux-linux-arm64" ]]; then
        continue
      fi
    fi
    SETUP_FILE="${candidate}"
    break
  fi
done

if [[ -z "${SETUP_FILE}" ]]; then
  echo "setup.sh tidak ditemukan untuk switch provider edge." >&2
  exit 1
fi

# shellcheck source=/usr/local/lib/autoscript-setup/setup.sh
source "${SETUP_FILE}"

export EDGE_PROVIDER="${TARGET_PROVIDER}"
export EDGE_ACTIVATE_RUNTIME=true

if [[ "${TARGET_PROVIDER}" == "go" ]]; then
  edge_runtime_preflight_or_die
fi
write_edge_runtime_env
write_nginx_config
install_edge_provider_stack

if [[ "${TARGET_PROVIDER}" == "go" && "${EDGE_HAPROXY_FALLBACK_ENABLED:-true}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  stage_edge_haproxy_standby_runtime
fi

echo "Edge provider aktif: ${TARGET_PROVIDER}"
